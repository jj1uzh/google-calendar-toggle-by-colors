{
  "manifest_version": 3,
  "name": "google-calendar-toggle-by-color",
  "description": "A browser extension to toggle calendars by colors",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "gcaltoggle@jj1uzh.net",
      "strict_min_version": "126.0"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "google-calendar-toggle-by-color",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://calendar.google.com/"
  ]
}
